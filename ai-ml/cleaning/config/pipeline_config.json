{
  "hazard_event": {
    "schema_mapping": {
      "event_id": "hazard_event_id",
      "event_type": "hazard_type",
      "severity": "severity_level",
      "timestamp": "start_time"
    },
    "missing_values": {
      "drop": ["hazard_event_id", "start_time"],
      "fill": {
        "hazard_type": "unknown",
        "severity_level": "low",
        "event_status": "monitoring"
      }
    },
    "duplicates": {
      "subset": ["hazard_event_id"]
    },
    "type_conversion": {
      "datetime": ["start_time"]
    },
    "string_standardisation": {
      "lower": ["severity_level", "event_status"],
      "capitalize": ["hazard_type"]
    },
    "validation": {
      "severity_level": ["low", "medium", "high", "critical"],
      "event_status": ["active", "resolved", "monitoring"]
    }
  },
  "cyber_threat": {
    "schema_mapping": {
      "id": "threat_id",
      "type_of_threat": "threat_type",
      "risk": "risk_level",
      "time_detected": "detected_at"
    },
    "missing_values": {
      "drop": ["threat_id", "detected_at"],
      "fill": {
        "threat_type": "unknown",
        "risk_level": "low",
        "status": "monitoring"
      }
    },
    "duplicates": {
      "subset": ["threat_id"]
    },
    "type_conversion": {
      "datetime": ["detected_at"],
      "int": ["threat_id"]
    },
    "string_standardisation": {
      "lower": ["risk_level", "status"],
      "capitalize": ["threat_type"]
    },
    "validation": {
      "risk_level": ["low", "medium", "high", "critical"],
      "status": ["active", "monitoring", "resolved", "archived"]
    }
  }
}