{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "rootDir": ".",
    "outDir": "../dist/api-gateway",
    "composite": true,
    "strict": true,
    "esModuleInterop": true,
    "moduleResolution": "node",
    "skipLibCheck": true,
    "strictPropertyInitialization": false,
    "noEmit": false,
    "incremental": true,
    "tsBuildInfoFile": "../../.tsbuildinfo/api-gateway.tsbuildinfo"
  },
  "include": ["src"],
   "references": [
    { "path": "../libs/common" }   // path **must point to folder with tsconfig.json**
  ]
}
