{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "rootDir": ".",
    "outDir": "../dist/api-gateway",
    "composite": true,
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "moduleResolution": "node",
    "skipLibCheck": true,
    "strictPropertyInitialization": false,
    "noEmit": false,
    "incremental": true,
    "baseUrl": "..",
    "paths": {
      "@phoenix/common": ["libs/common/src/index.ts"],
      "@phoenix/common/*": ["libs/common/src/*"]
    }
  },
  "include": ["src"],
  "references": [{ "path": "../libs/common" }]
}
