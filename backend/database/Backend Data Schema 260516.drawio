ute&quot;&gt;&amp;nbsp;&lt;span class=&quot;html-attribute-name&quot;&gt;tz&lt;/span&gt;=&quot;&lt;span class=&quot;html-attribute-value&quot;&gt;EDT&lt;/span&gt;&quot;&lt;/span&gt;&amp;gt;&lt;/span&gt;2025-11-26T04:43:44+11:00&lt;span class=&quot;html-tag&quot;&gt;&amp;lt;/issue-time-local&amp;gt;&lt;/span&gt;&lt;/div&gt;&lt;div class=&quot;line&quot;&gt;&lt;span class=&quot;html-tag&quot;&gt;&amp;lt;sent-time&amp;gt;&lt;/span&gt;2025-11-25T17:43:44Z&lt;span class=&quot;html-tag&quot;&gt;&amp;lt;/sent-time&amp;gt;&lt;/span&gt;&lt;/div&gt;&lt;div class=&quot;line&quot;&gt;&lt;span class=&quot;html-tag&quot;&gt;&amp;lt;expiry-time&amp;gt;&lt;/span&gt;2025-11-26T13:00:00Z&lt;span class=&quot;html-tag&quot;&gt;&amp;lt;/expiry-time&amp;gt;&lt;/span&gt;&lt;/div&gt;&lt;div class=&quot;line&quot;&gt;&lt;span class=&quot;html-tag&quot;&gt;&amp;lt;validity-bgn-time-local&lt;span class=&quot;html-attribute&quot;&gt;&amp;nbsp;&lt;span class=&quot;html-attribute-name&quot;&gt;tz&lt;/span&gt;=&quot;&lt;span class=&quot;html-attribute-value&quot;&gt;EDT&lt;/span&gt;&quot;&lt;/span&gt;&amp;gt;&lt;/span&gt;2025-11-26T03:00:00+11:00&lt;span class=&quot;html-tag&quot;&gt;&amp;lt;/validity-bgn-time-local&amp;gt;&lt;/span&gt;&lt;/div&gt;&lt;div class=&quot;line&quot;&gt;&lt;span class=&quot;html-tag&quot;&gt;&amp;lt;validity-end-time-local&lt;span class=&quot;html-attribute&quot;&gt;&amp;nbsp;&lt;span class=&quot;html-attribute-name&quot;&gt;tz&lt;/span&gt;=&quot;&lt;span class=&quot;html-attribute-value&quot;&gt;EDT&lt;/span&gt;&quot;&lt;/span&gt;&amp;gt;&lt;/span&gt;2025-11-26T23:59:59+11:00&lt;span class=&quot;html-tag&quot;&gt;&amp;lt;/validity-end-time-local&amp;gt;&lt;/span&gt;&lt;/div&gt;&lt;div class=&quot;line&quot;&gt;&lt;span class=&quot;html-tag&quot;&gt;&amp;lt;next-routine-issue-time-utc&amp;gt;&lt;/span&gt;2025-11-26T06:00:00Z&lt;span class=&quot;html-tag&quot;&gt;&amp;lt;/next-routine-issue-time-utc&amp;gt;&lt;/span&gt;&lt;/div&gt;&lt;div class=&quot;line&quot;&gt;&lt;span class=&quot;html-tag&quot;&gt;&amp;lt;next-routine-issue-time-local&lt;span class=&quot;html-attribute&quot;&gt;&amp;nbsp;&lt;span class=&quot;html-attribute-name&quot;&gt;tz&lt;/span&gt;=&quot;&lt;span class=&quot;html-attribute-value&quot;&gt;EDT&lt;/span&gt;&quot;&lt;/span&gt;&amp;gt;&lt;/span&gt;2025-11-26T17:00:00+11:00&lt;span class=&quot;html-tag&quot;&gt;&amp;lt;/next-routine-issue-time-local&amp;gt;&lt;/span&gt;&lt;/div&gt;&lt;div class=&quot;line&quot;&gt;&lt;span class=&quot;html-tag&quot;&gt;&amp;lt;status&amp;gt;&lt;/span&gt;O&lt;span class=&quot;html-tag&quot;&gt;&amp;lt;/status&amp;gt;&lt;/span&gt;&lt;/div&gt;&lt;div class=&quot;line&quot;&gt;&lt;span class=&quot;html-tag&quot;&gt;&amp;lt;service&amp;gt;&lt;/span&gt;WSF&lt;span class=&quot;html-tag&quot;&gt;&amp;lt;/service&amp;gt;&lt;/span&gt;&lt;/div&gt;&lt;div class=&quot;line&quot;&gt;&lt;span class=&quot;html-tag&quot;&gt;&amp;lt;sub-service&amp;gt;&lt;/span&gt;WFW&lt;span class=&quot;html-tag&quot;&gt;&amp;lt;/sub-service&amp;gt;&lt;/span&gt;&lt;/div&gt;&lt;div class=&quot;line&quot;&gt;&lt;span class=&quot;html-tag&quot;&gt;&amp;lt;product-type&amp;gt;&lt;/span&gt;W&lt;span class=&quot;html-tag&quot;&gt;&amp;lt;/product-type&amp;gt;&lt;/span&gt;&lt;/div&gt;&lt;div class=&quot;line&quot;&gt;&lt;span class=&quot;html-tag&quot;&gt;&amp;lt;phase&amp;gt;&lt;/span&gt;REN&lt;span class=&quot;html-tag&quot;&gt;&amp;lt;/phase&amp;gt;&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;line&quot;&gt;&lt;span class=&quot;html-tag&quot;&gt;&amp;lt;/amoc&amp;gt;&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;folder&quot; id=&quot;folder3&quot;&gt;&lt;div class=&quot;line&quot;&gt;&lt;span class=&quot;html-tag&quot;&gt;&amp;lt;warning&amp;gt;&lt;/span&gt;&lt;/div&gt;&lt;div class=&quot;opened&quot; style=&quot;margin-left: 1em;&quot;&gt;&lt;div class=&quot;folder&quot; id=&quot;folder4&quot;&gt;&lt;div class=&quot;line&quot;&gt;&lt;span class=&quot;html-tag&quot;&gt;&amp;lt;warning-info&amp;gt;&lt;/span&gt;&lt;/div&gt;&lt;div class=&quot;opened&quot; style=&quot;margin-left: 1em;&quot;&gt;&lt;div class=&quot;line&quot;&gt;&lt;span&gt;&lt;span class=&quot;html-tag&quot;&gt;&amp;lt;text&lt;span class=&quot;html-attribute&quot;&gt;&amp;nbsp;&lt;span class=&quot;html-attribute-name&quot;&gt;type&lt;/span&gt;=&quot;&lt;span class=&quot;html-attribute-value&quot;&gt;warning_title&lt;/span&gt;&quot;&lt;/span&gt;&amp;gt;&lt;/span&gt;&lt;span&gt;&lt;span&gt;&lt;span style=&quot;background-color: rgb(212, 225, 245);&quot;&gt;Fire Weather Warnin&lt;/span&gt;&lt;span style=&quot;background-color: rgb(255, 255, 204);&quot;&gt;g&lt;/span&gt;&lt;/span&gt;&lt;span class=&quot;html-tag&quot;&gt;&amp;lt;/text&amp;gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/div&gt;&lt;div class=&quot;line&quot;&gt;&lt;span&gt;&lt;span class=&quot;html-tag&quot;&gt;&amp;lt;text&lt;span class=&quot;html-attribute&quot;&gt;&amp;nbsp;&lt;span class=&quot;html-attribute-name&quot;&gt;type&lt;/span&gt;=&quot;&lt;span class=&quot;html-attribute-value&quot;&gt;warning_area_summary&lt;/span&gt;&quot;&lt;/span&gt;&amp;gt;&lt;/span&gt;&lt;span&gt;&lt;font style=&quot;&quot;&gt;Greater Hunter, Greater Sydney Region, Illawarra/Shoalhaven, Central Ranges, North Western, Upper Central West Plains, Lower Central West Plains, Southern Slopes, Eastern Riverina, Southern Riverina and Northern Riverina fire weather district&lt;/font&gt;s&lt;/span&gt;&lt;span class=&quot;html-tag&quot;&gt;&lt;span&gt;&amp;lt;/te&lt;/span&gt;xt&amp;gt;&lt;/span&gt;&lt;/span&gt;&lt;/div&gt;&lt;div class=&quot;folder&quot; id=&quot;folder5&quot;&gt;&lt;div class=&quot;line&quot;&gt;&lt;span class=&quot;html-tag&quot;&gt;&amp;lt;text&lt;span class=&quot;html-attribute&quot;&gt;&amp;nbsp;&lt;span class=&quot;html-attribute-name&quot;&gt;type&lt;/span&gt;=&quot;&lt;span class=&quot;html-attribute-value&quot;&gt;warning_advice&lt;/span&gt;&quot;&lt;/span&gt;&amp;gt;&lt;/span&gt;&lt;/div&gt;&lt;div class=&quot;opened&quot; style=&quot;margin-left: 1em;&quot;&gt;&lt;div class=&quot;line&quot;&gt;&lt;span class=&quot;html-tag&quot;&gt;&amp;lt;p&amp;gt;&lt;/span&gt;The NSW Rural Fire Service advises you to:&lt;span class=&quot;html-tag&quot;&gt;&amp;lt;/p&amp;gt;&lt;/span&gt;&lt;/div&gt;&lt;div class=&quot;line&quot;&gt;&lt;span class=&quot;html-tag&quot;&gt;&amp;lt;p&amp;gt;&lt;/span&gt;Action your Bushfire Survival Plan now.&lt;span class=&quot;html-tag&quot;&gt;&amp;lt;/p&amp;gt;&lt;/span&gt;&lt;/div&gt;&lt;div class=&quot;line&quot;&gt;&lt;span class=&quot;html-tag&quot;&gt;&amp;lt;p&amp;gt;&lt;/span&gt;Monitor the fire and weather situation through your local radio station, www.rfs.nsw.gov.au and www.bom.gov.au.&lt;span class=&quot;html-tag&quot;&gt;&amp;lt;/p&amp;gt;&lt;/span&gt;&lt;/div&gt;&lt;div class=&quot;line&quot;&gt;&lt;span class=&quot;html-tag&quot;&gt;&amp;lt;p&amp;gt;&lt;/span&gt;Call 000 (Triple Zero) in an emergency.&lt;span class=&quot;html-tag&quot;&gt;&amp;lt;/p&amp;gt;&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;line&quot;&gt;&lt;span class=&quot;html-tag&quot;&gt;&amp;lt;/text&amp;gt;&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;line&quot;&gt;&lt;span class=&quot;html-tag&quot;&gt;&amp;lt;text&lt;span class=&quot;html-attribute&quot;&gt;&amp;nbsp;&lt;span class=&quot;html-attribute-name&quot;&gt;type&lt;/span&gt;=&quot;&lt;span class=&quot;html-attribute-value&quot;&gt;warning_next_issue&lt;/span&gt;&quot;&lt;/span&gt;&amp;gt;&lt;/span&gt;No further warnings will be issued for this event, but the situation will continue to be monitored and further warnings issued if necessary.&lt;span class=&quot;html-tag&quot;&gt;&amp;lt;/text&amp;gt;&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;line&quot;&gt;&lt;span class=&quot;html-tag&quot;&gt;&amp;lt;/warning-info&amp;gt;&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;line&quot;&gt;&lt;span class=&quot;comment html-comment&quot; style=&quot;white-space: pre;&quot;&gt;&amp;lt;!--  --&amp;