{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "declaration": true,
    "strict": true,
    "rootDir": ".",
    "outDir": "../../dist/libs/common",
    "composite": true,
    "esModuleInterop": true,
    "noEmit": false,
    "incremental": true,
    "tsBuildInfoFile": "../../.tsbuildinfo/common.tsbuildinfo",
    "types": ["node"]
  },
  "include": ["src", "index.ts"],
  "exclude": ["node_modules", "dist", "test", "**/*spec.ts"]
}
